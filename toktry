local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local playerGui = LocalPlayer:WaitForChild("PlayerGui")
local hud = playerGui:WaitForChild("HUD", 5)

if hud then
   local bottomLeft = hud:WaitForChild("BottomLeft", 5)
    
    if bottomLeft then
        local tradeTokens = bottomLeft:WaitForChild("TradeTokens", 5)
        
        if tradeTokens then
            local function setMaxValue(element)
                element.Text = math.huge
                element.TextScaled = true
                
                element:GetPropertyChangedSignal("Text"):Connect(function()
                    if not tonumber(element.Text) then return end
                    element.Text = math.huge
                end)
            end
            
            for _, child in ipairs(tradeTokens:GetDescendants()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") then
                    setMaxValue(child)
                end
            end
            
            if tradeTokens:IsA("TextLabel") or tradeTokens:IsA("TextButton") then
                setMaxValue(tradeTokens)
            end
        end
    end
end
