local Players = game:GetService("Players")
local player = Players.LocalPlayer

local tokens = 0 -- local token storage

-- GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 350, 0, 220)
frame.Position = UDim2.new(0.5, 0, 0.5, 0)
frame.AnchorPoint = Vector2.new(0.5, 0.5)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Parent = screenGui

Instance.new("UICorner", frame).CornerRadius = UDim.new(0,20)

-- Title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,40)
title.BackgroundTransparency = 1
title.Text = "Token Manager"
title.TextColor3 = Color3.fromRGB(0,255,170)
title.Font = Enum.Font.GothamBold
title.TextScaled = true
title.Parent = frame

-- Token Display
local tokenLabel = Instance.new("TextLabel")
tokenLabel.Size = UDim2.new(1,-40,0,50)
tokenLabel.Position = UDim2.new(0,20,0,60)
tokenLabel.BackgroundColor3 = Color3.fromRGB(40,40,40)
tokenLabel.TextColor3 = Color3.new(1,1,1)
tokenLabel.Font = Enum.Font.GothamBlack
tokenLabel.TextScaled = true
tokenLabel.Text = "Tokens: 0"
tokenLabel.Parent = frame

Instance.new("UICorner", tokenLabel).CornerRadius = UDim.new(0,15)

-- Input Box
local inputBox = Instance.new("TextBox")
inputBox.Size = UDim2.new(1,-40,0,40)
inputBox.Position = UDim2.new(0,20,0,120)
inputBox.PlaceholderText = "Enter amount..."
inputBox.Text = ""
inputBox.TextScaled = true
inputBox.BackgroundColor3 = Color3.fromRGB(35,35,35)
inputBox.TextColor3 = Color3.new(1,1,1)
inputBox.Parent = frame

Instance.new("UICorner", inputBox).CornerRadius = UDim.new(0,15)

-- Add Button
local addButton = Instance.new("TextButton")
addButton.Size = UDim2.new(1,-40,0,40)
addButton.Position = UDim2.new(0,20,0,170)
addButton.Text = "Add Tokens"
addButton.TextScaled = true
addButton.BackgroundColor3 = Color3.fromRGB(0,255,170)
addButton.TextColor3 = Color3.new(0,0,0)
addButton.Parent = frame

Instance.new("UICorner", addButton).CornerRadius = UDim.new(0,15)

-- Button Function
addButton.MouseButton1Click:Connect(function()
	local amount = tonumber(inputBox.Text)
	
	if amount and amount > 0 then
		tokens += amount
		tokenLabel.Text = "Tokens: " .. tokens
		inputBox.Text = ""
	end
end)
